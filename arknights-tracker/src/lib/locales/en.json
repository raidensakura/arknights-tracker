  "privacy": {
    "title": "Privacy Policy",
    "analytics_title": "Privacy & Analytics",
    "analytics_text1": "We use Firebase Analytics (Google Analytics) to collect traffic and performance metrics to improve Goyfield.moe.",
    "analytics_text2": "Goyfield.moe uses localStorage technology to store your user preferences (e.g., selected server, theme, language) and pull history data locally on your device.",
    "tracker_title": "Pull Tracker",
    "tracker_text1": "By default, all imported pull data is saved locally on your device. Your import link (containing a temporary token) is sent to the Goyfield.moe backend server solely to connect with the official game API and retrieve your history. The link itself, tokens, or any personal account data are not shared with third parties and are not stored on the server in plain text.",
    "tracker_text2": "In the event of a system error during import, the link may be temporarily saved in the administrator logs to identify and fix bugs.",
    "global_title": "Global Statistics",
    "global_text": "When you import your history, certain anonymized information about your pulls (item type, rarity, time, banner) is saved on our server. This data is linked to an anonymous generated identifier (UID) and is used to power the \"Global Statistics\" section.",
    "cloud_title": "Cloud Sync",
    "cloud_text1": "Goyfield.moe provides the option to link your Google account to create cloud backups of your pull data. Your username and email address are displayed solely within the settings interface and are not shared with third parties.",
    "cloud_text2": "Unlike local storage, when using this feature, your pull data is securely stored in our cloud database (Firebase). You can sign out of your account at any time via Settings.",
    "close": "Close"
  },
